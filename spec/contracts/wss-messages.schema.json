    "ConsoleQueueDepthMessage": {
      "description": "Periodic push (every 5 seconds) from the orchestrator to Console connections with current queue depth. Allows the console to show queue depth without polling GET /metrics/queue-depth.",
      "type": "object",
      "required": ["type", "id", "ts", "payload"],
      "properties": {
        "type": { "type": "string", "const": "queue_depth" },
