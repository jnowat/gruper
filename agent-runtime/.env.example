# Copy this file to .env and fill in the values before starting the agent.
# Lines marked REQUIRED must be set — the runtime refuses to start without them.

# ── Orchestrator ─────────────────────────────────────────────────────────────
# WSS endpoint of the Gruper Orchestrator (must end with /v1/agents/ws)
ORCHESTRATOR_URL=wss://orchestrator.example.com/v1/agents/ws

# REQUIRED: UUID from POST /v1/agents
AGENT_ID=

# REQUIRED: JWT from POST /v1/auth/token
JWT_TOKEN=

# ── Local Ollama ──────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434

# ── Offline queue ─────────────────────────────────────────────────────────────
# SQLite file created on first run in the current working directory
DB_PATH=agent.db

# ── Heartbeat ─────────────────────────────────────────────────────────────────
# Must be well under the orchestrator's HEARTBEAT_TIMEOUT_S (default 90s)
HEARTBEAT_INTERVAL_S=30

# ── Capabilities ─────────────────────────────────────────────────────────────
# JSON capability descriptor sent to the orchestrator on registration.
# Update models to match what is actually available via `ollama list`.
CAPABILITIES={"models":["llama3.1:8b"],"roles":["analyst"],"tools":[],"hardware":{"cpu_cores":4,"ram_gb":8}}

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
