# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# PyInstaller build output (WP-31 desktop packaging) — built by
# scripts/build-desktop.sh/.ps1 or CI, never committed
/dist/
/build/
.build-venv/

# Tauri sidecar binary (WP-32) — staged by scripts/build-desktop.sh/.ps1 or
# CI from the PyInstaller build above; platform-specific, never committed
console/src-tauri/binaries/

# Virtual environments
.venv/
.venv-*/
venv/
env/

# Local env files (never commit secrets)
.env
.env.*
!.env.example

# Auto-generated JWT secret for zero-config desktop runs (orchestrator/config.py)
.gruper_jwt_secret

# SQLite DBs created at runtime (agent offline queue; orchestrator desktop-default store)
agent.db
orchestrator.db
*.sqlite
*.sqlite3
*.sqlite3-wal
*.sqlite3-shm
orchestrator.db-wal
orchestrator.db-shm

# WP-06 end-to-end harness scratch (logs, results, per-run DBs)
/tmp/wp06/

# Editor / OS noise
.DS_Store
Thumbs.db
