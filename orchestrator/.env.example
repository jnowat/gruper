# Copy this file to .env and fill in the values before running.
# Variables marked REQUIRED must be set — the server refuses to start without them.

# ── PostgreSQL (used by docker-compose; also embedded in DATABASE_URL) ──────
POSTGRES_DB=gruper
POSTGRES_USER=gruper
POSTGRES_PASSWORD=change-me          # REQUIRED

# ── Orchestrator ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://gruper:change-me@localhost:5432/gruper

# REQUIRED: generate with: openssl rand -hex 32
JWT_SECRET=change-me-use-openssl-rand-hex-32

# Token lifetime in minutes (default: 60)
JWT_EXPIRE_MINUTES=60

# Heartbeat watchdog: agents are marked offline after HEARTBEAT_TIMEOUT_S of silence.
# The watchdog polls every HEARTBEAT_CHECK_INTERVAL_S seconds.
HEARTBEAT_TIMEOUT_S=90
HEARTBEAT_CHECK_INTERVAL_S=15

# CORS allowed origins.  Value must be a JSON array.
# Use ["*"] for local development only; restrict in production.
# Example: CORS_ORIGINS=["https://console.example.com"]
CORS_ORIGINS=["*"]

# Python logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
